# ==================== DATABASE ====================
# Development: SQLite
DATABASE_PROVIDER=sqlite
DATABASE_URL=file:./dev.db

# Production on Railway: PostgreSQL (Railway auto-provides this)
# DATABASE_PROVIDER=postgresql
# DATABASE_URL=postgresql://user:password@host:5432/finance_dashboard

# ==================== SERVER ====================
PORT=3000
NODE_ENV=development

# ==================== JWT AUTHENTICATION ====================
# Use: openssl rand -base64 32 to generate new secret
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_chars
JWT_EXPIRY=7d

# ==================== CORS ====================
# Development: Multiple origins (comma-separated)
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Production: Use Railway Dashboard to set
# CORS_ORIGIN=https://your-frontend-domain.vercel.app

# ==================== LOGGING ====================
LOG_LEVEL=debug
